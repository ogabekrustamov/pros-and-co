7:["$","section",null,{"className":"flex w-full border-t px-12 py-24 gap-20 border-t-[#1a1a1a33]","children":[["$","div",null,{"className":"flex max-w-[820px] flex-col flex-1 gap-7","children":[["$","div",null,{"className":"flex items-center gap-3","children":[["$","span",null,{"className":"text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[3.08px] uppercase","children":"§ 01."}],["$","span",null,{"className":"text-[#1a1a1aa6] font-['Oswald'] text-[11px] leading-normal tracking-[3.08px] uppercase","children":"The Premise"}]]}],["$","div",null,{"className":"flex items-start gap-5","children":[["$","span",null,{"className":"shrink-0 font-['Oswald'] text-[180px] leading-[0.78] tracking-[-7.2px] uppercase","children":"W"}],["$","p",null,{"className":"pt-2 text-[#1a1a1a] text-xl leading-[1.55]","children":"e have spent ten years watching writing tools mistake speed for help. They finish our sentences before we have finished thinking them, predict the word the room expects, and call it intelligence. We disagree, politely."}]]}],["$","p",null,{"className":"text-[#1a1a1ae6] text-lg leading-[1.65]","children":"Writing is not the typing. Writing is the small, structural act of choosing a sentence over the sentence next to it — an act that requires the writer to be slightly uncomfortable, slightly slower than the machine. Prose & Co. was built to protect that discomfort, not to relieve it."}],["$","blockquote",null,{"className":"max-w-[680px] pl-7 text-[#1a1a1a] text-4xl italic leading-tight my-4 border-l-[3px] border-l-[#2563eb]","children":"\"We do not finish your sentence. We hand it back to you, slightly heavier than it was.\""}],["$","p",null,{"className":"text-[#1a1a1ae6] text-lg leading-[1.65]","children":"This is a manifesto, in the old sense: a short list of beliefs we are willing to be unfashionable about. There are five of them. They are written in plain English so that we cannot wriggle out of any of them later."}]]}],["$","div",null,{"className":"flex w-[320px] flex-col shrink-0 pt-2 gap-7","children":[["$","div",null,{"className":"flex flex-col pl-5 border-l gap-2.5 border-l-[#1a1a1a33]","children":[["$","span",null,{"className":"text-[#2563eb] font-['Oswald'] text-[10px] leading-normal tracking-[2.8px] uppercase","children":"Marginalia — Note 1"}],["$","p",null,{"className":"text-[#1a1a1abf] text-[15px] italic leading-[1.55]","children":"\"Speed is a virtue in messengers, not in editors.\" — pinned above M. Reinhardt's desk, on a strip of masking tape."}]]}],["$","div",null,{"className":"flex flex-col border p-5 gap-2.5 border-[#1a1a1a33]","children":[["$","span",null,{"className":"text-[#1a1a1a8c] font-['Oswald'] text-[10px] leading-normal tracking-[2.8px] uppercase","children":"An Honest Number"}],["$","div",null,{"className":"flex items-baseline gap-[18px]","children":[["$","span",null,{"className":"font-['Oswald'] text-7xl leading-[0.9]","children":"71"}],["$","span",null,{"className":"text-[#2563eb] font-['Oswald'] text-[28px] leading-[0.9]","children":"%"}]]}],["$","p",null,{"className":"text-[#1a1a1ab3] text-[13px] leading-normal","children":"Of our subscribers told us, unprompted, that the Editor \"does less than I expected, on purpose.\" We took it as a compliment."}]]}],["$","div",null,{"className":"flex flex-col pl-5 border-l gap-2.5 border-l-[#1a1a1a33]","children":[["$","span",null,{"className":"text-[#2563eb] font-['Oswald'] text-[10px] leading-normal tracking-[2.8px] uppercase","children":"Marginalia — Note 2"}],["$","p",null,{"className":"text-[#1a1a1abf] text-[15px] italic leading-[1.55]","children":"If the room expects the word, the Editor will quietly suggest the second-best one. Surprise is a feature."}]]}]]}]]}]
8:["$","section",null,{"className":"flex w-full flex-col bg-[#1a1a1a] text-[#f7f6f3] px-12 py-[112px] gap-12","children":[["$","div",null,{"className":"flex justify-between items-end pb-7 border-b gap-12 border-b-[#f7f6f333]","children":[["$","div",null,{"className":"flex flex-col gap-3.5","children":[["$","div",null,{"className":"flex items-center gap-3","children":[["$","div",null,{"className":"flex w-7 h-0.5 bg-[#2563eb]"}],["$","span",null,{"className":"font-['Oswald'] text-[11px] leading-normal tracking-[3.08px] uppercase","children":"§ 02. — Five Tenets, Plainly Stated"}]]}],["$","span",null,{"className":"font-['Oswald'] text-[clamp(48px,8vw,112px)] leading-[0.92] tracking-[-2.24px] uppercase","children":"What We Believe."}]]}],["$","p",null,{"className":"max-w-[320px] pb-4 text-[#f7f6f3a6] text-base italic","children":"Pin them up. Argue with us. Write back if any of them are wrong — we will print the letter."}]]}],["$","div",null,{"className":"flex flex-col","children":[["$","div","01",{"className":"flex border-b py-9 gap-10 border-b-[#f7f6f326]","children":[["$","span",null,{"className":"w-[160px] shrink-0 text-[#2563eb] font-['Oswald'] text-8xl leading-[0.9] tracking-[-1.92px]","children":"01"}],["$","div",null,{"className":"flex flex-col pt-2 flex-1 gap-3.5","children":[["$","h3",null,{"className":"font-['Oswald'] text-[44px] leading-none tracking-[-0.44px] uppercase","children":"The Sentence Is The Unit."}],["$","p",null,{"className":"max-w-[760px] text-[#f7f6f3d9] text-[17px] leading-[1.6]","children":"Not the paragraph. Not the document. The Editor is built around the sentence because that is where thinking actually happens — one decision at a time, one line at a time."}]]}]]}],["$","div","02",{"className":"flex border-b py-9 gap-10 border-b-[#f7f6f326]","children":[["$","span",null,{"className":"w-[160px] shrink-0 text-[#2563eb] font-['Oswald'] text-8xl leading-[0.9] tracking-[-1.92px]","children":"02"}],["$","div",null,{"className":"flex flex-col pt-2 flex-1 gap-3.5","children":[["$","h3",null,{"className":"font-['Oswald'] text-[44px] leading-none tracking-[-0.44px] uppercase","children":"Suggest, Never Substitute."}],["$","p",null,{"className":"max-w-[760px] text-[#f7f6f3d9] text-[17px] leading-[1.6]","children":"We will never quietly replace your words with ours. The Editor proposes, in the margin, the way a real editor does. The author keeps the pen."}]]}]]}],["$","div","03",{"className":"flex border-b py-9 gap-10 border-b-[#f7f6f326]","children":[["$","span",null,{"className":"w-[160px] shrink-0 text-[#2563eb] font-['Oswald'] text-8xl leading-[0.9] tracking-[-1.92px]","children":"03"}],["$","div",null,{"className":"flex flex-col pt-2 flex-1 gap-3.5","children":[["$","h3",null,{"className":"font-['Oswald'] text-[44px] leading-none tracking-[-0.44px] uppercase","children":"Cadence Over Correctness."}],["$","p",null,{"className":"max-w-[760px] text-[#f7f6f3d9] text-[17px] leading-[1.6]","children":"Grammar is a floor, not a ceiling. We will defend a comma splice if it earns its keep, and we will argue against a perfectly correct sentence if it bores us both."}]]}]]}],["$","div","04",{"className":"flex border-b py-9 gap-10 border-b-[#f7f6f326]","children":[["$","span",null,{"className":"w-[160px] shrink-0 text-[#2563eb] font-['Oswald'] text-8xl leading-[0.9] tracking-[-1.92px]","children":"04"}],["$","div",null,{"className":"flex flex-col pt-2 flex-1 gap-3.5","children":[["$","h3",null,{"className":"font-['Oswald'] text-[44px] leading-none tracking-[-0.44px] uppercase","children":"Sources, Visible. Always."}],["$","p",null,{"className":"max-w-[760px] text-[#f7f6f3d9] text-[17px] leading-[1.6]","children":"Every fact carries its citation. Every guess is labelled a guess. If the Editor is uncertain, it says so, in a tone of voice that does not pretend otherwise."}]]}]]}],"$Lf"]}]]}]
9:["$","section",null,{"className":"flex w-full px-12 py-[112px] gap-16","children":[["$","div",null,{"className":"flex flex-col flex-1 gap-5","children":[["$","div",null,{"className":"flex items-center gap-3","children":[["$","div",null,{"className":"flex w-7 h-0.5 bg-[#2563eb]"}],["$","span",null,{"className":"font-['Oswald'] text-[11px] leading-normal tracking-[3.08px] uppercase","children":"§ 03. — Apophatic Definitions"}]]}],["$","span",null,{"className":"font-['Oswald'] text-8xl leading-[0.92] tracking-[-1.92px] uppercase","children":"What We Will Not Do."}],["$","p",null,{"className":"max-w-[500px] mt-2 text-[#1a1a1acc] text-lg leading-[1.6]","children":"A manifesto is also a list of refusals. Some of these are technically possible. We have chosen not to ship them, and we would like the choice to be on the record."}]]}],["$","div",null,{"className":"flex flex-col flex-1","children":[["$","div","01 .",{"className":"flex py-5 gap-5","children":[["$","span",null,{"className":"w-10 shrink-0 pt-1 text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[2.64px] uppercase","children":"01 ."}],["$","div",null,{"className":"flex flex-col gap-1.5","children":[["$","h4",null,{"className":"font-['Oswald'] text-xl leading-[1.15] uppercase","children":"We will not autocomplete in the body of the document."}],["$","p",null,{"className":"max-w-[520px] text-[#1a1a1abf] text-[15px] leading-[1.55]","children":"Ghost text trains writers to accept the obvious word. We refuse to be a worse version of your own voice."}]]}]]}],["$","div","02 .",{"className":"flex py-5 gap-5","children":[["$","span",null,{"className":"w-10 shrink-0 pt-1 text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[2.64px] uppercase","children":"02 ."}],["$","div",null,{"className":"flex flex-col gap-1.5","children":[["$","h4",null,{"className":"font-['Oswald'] text-xl leading-[1.15] uppercase","children":"We will not score your writing out of one hundred."}],["$","p",null,{"className":"max-w-[520px] text-[#1a1a1abf] text-[15px] leading-[1.55]","children":"There is no such number. Any product that supplies one is selling theatre."}]]}]]}],["$","div","03 .",{"className":"flex py-5 gap-5","children":[["$","span",null,{"className":"w-10 shrink-0 pt-1 text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[2.64px] uppercase","children":"03 ."}],["$","div",null,{"className":"flex flex-col gap-1.5","children":[["$","h4",null,{"className":"font-['Oswald'] text-xl leading-[1.15] uppercase","children":"We will not train on customer drafts."}],["$","p",null,{"className":"max-w-[520px] text-[#1a1a1abf] text-[15px] leading-[1.55]","children":"Ever. Not anonymised, not aggregated, not “to improve the service.” Your sentences are yours."}]]}]]}],["$","div","04 .",{"className":"flex py-5 gap-5","children":[["$","span",null,{"className":"w-10 shrink-0 pt-1 text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[2.64px] uppercase","children":"04 ."}],["$","div",null,{"className":"flex flex-col gap-1.5","children":[["$","h4",null,{"className":"font-['Oswald'] text-xl leading-[1.15] uppercase","children":"We will not bury the model behind a personality."}],["$","p",null,{"className":"max-w-[520px] text-[#1a1a1abf] text-[15px] leading-[1.55]","children":"No mascots, no first-name AI, no \"hello, friend!\" The Editor speaks in the voice of an editor: brief, particular, slightly tired."}]]}]]}],["$","div","05 .",{"className":"flex py-5 gap-5","children":[["$","span",null,{"className":"w-10 shrink-0 pt-1 text-[#2563eb] font-['Oswald'] text-[11px] leading-normal tracking-[2.64px] uppercase","children":"05 ."}],["$","div",null,{"className":"flex flex-col gap-1.5","children":[["$","h4",null,{"className":"font-['Oswald'] text-xl leading-[1.15] uppercase","children":"We will not chase the leaderboard."}],["$","p",null,{"className":"max-w-[520px] text-[#1a1a1abf] text-[15px] leading-[1.55]","children":"We optimise for one number: the percentage of suggestions the writer actually accepts and keeps in the final draft. Nothing else."}]]}]]}]]}]]}]
